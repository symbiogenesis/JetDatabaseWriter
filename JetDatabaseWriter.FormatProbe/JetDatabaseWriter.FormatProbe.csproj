<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>JetDatabaseWriter.FormatProbe</RootNamespace>
    <AssemblyName>JetDatabaseWriter.FormatProbe</AssemblyName>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <!-- Diagnostic CLI: disable strict library-grade analyzers and warnings-as-errors. -->
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <EnableNETAnalyzers>false</EnableNETAnalyzers>
    <RunAnalyzers>false</RunAnalyzers>
    <RunAnalyzersDuringBuild>false</RunAnalyzersDuringBuild>
    <EnforceCodeStyleInBuild>false</EnforceCodeStyleInBuild>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\JetDatabaseWriter\JetDatabaseWriter.csproj" />
  </ItemGroup>
  <ItemGroup>
    <!-- Drop the analyzers Directory.Build.props pulls in. -->
    <PackageReference Remove="StyleCop.Analyzers" />
    <PackageReference Remove="Roslynator.Analyzers" />
    <PackageReference Remove="Roslynator.Refactorings" />
  </ItemGroup>
</Project>
